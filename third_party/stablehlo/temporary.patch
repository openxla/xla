+struct FoldXorOpPattern : public ShapeOpRewritePattern<XorOp> {
+  using ShapeOpRewritePattern::ShapeOpRewritePattern;
+
+  LogicalResult matchAndRewrite(XorOp op,
+                                PatternRewriter& rewriter) const override {
+    auto resultType = op.getType();
+    FailureOr<TypedAttr> result;
+
+    TypedAttr lhsAttr, rhsAttr;
+    matchPattern(op.getLhs(), m_Constant(&lhsAttr));
+    matchPattern(op.getRhs(), m_Constant(&rhsAttr));
+
+    if (!lhsAttr || !rhsAttr)
+      return rewriter.notifyMatchFailure(op,
+                                         "lhs & rhs operands not constants");
+
+    SplatElementsAttr splatLhs = dyn_cast<SplatElementsAttr>(lhsAttr);
+    SplatElementsAttr splatRhs = dyn_cast<SplatElementsAttr>(rhsAttr);
+    if (splatLhs && splatRhs) {
+      APInt resultVal = FoldXor{}(splatLhs.getSplatValue<APInt>(),
+                                  splatRhs.getSplatValue<APInt>());
+      rewriter.replaceOpWithNewOp<ConstantOp>(
+          op, SplatElementsAttr::get(resultType, resultVal));
+      return success();
+    }
+
+    result = foldBinaryOpIntOrFloat(resultType, lhsAttr, rhsAttr, FoldXor{});
+    if (failed(result))
+      return rewriter.notifyMatchFailure(op, "folding failed");
+    rewriter.replaceOpWithNewOp<mlir::stablehlo::ConstantOp>(op,
+                                                             result.value());
+    return success();
+  }
+
+  struct FoldXor {
+    APInt operator()(APInt lhs, APInt rhs) const { return lhs ^ rhs; }
+
+    std::optional<APFloat> operator()(APFloat lhs, APFloat rhs) const {
+      return std::nullopt;
+    }
+  };
+};
