   // Attributes.
diff --ruN a/stablehlo/stablehlo/reference/Api.cpp b/stablehlo/stablehlo/reference/Api.cpp
--- stablehlo/stablehlo/reference/Api.cpp
+++ stablehlo/stablehlo/reference/Api.cpp
@@ -253,6 +253,24 @@
   return success();
 }
 
+// Several ops that are semantic subsets of other ops are deprecated in
+// StableHLO per rfcs/20240503-opset-deprecations.md, these ops can still be
+// handled by the interpreter with a pass to legalize them to their
+// replacements.
+//
+LogicalResult legalizeDeprecatedOps(ModuleOp module, func::FuncOp func) {
+  PassManager pm(module.getContext());
+  StablehloLegalizeDeprecatedOpsPassOptions options;
+  options.failOnUnusedOps = false;
+  pm.addNestedPass<func::FuncOp>(
+      stablehlo::createStablehloLegalizeDeprecatedOpsPass(options));
+  if (failed(pm.run(module))) {
+    return func.emitError("Failed to legalize deprecated ops in function: ")
+           << func.getName();
+  }
+  return success();
+}
+
 }  // namespace
 
 FailureOr<SmallVector<InterpreterValue>> evalModule(
@@ -267,6 +285,7 @@
   auto mainFunc = getMainFunction(module, config.mainFunction);
   if (failed(mainFunc) || failed(removeDynamism(module, *mainFunc, inputs)) ||
       failed(lowerQuantization(module, *mainFunc)) ||
+      failed(legalizeDeprecatedOps(module, *mainFunc)) ||
       failed(validateEntrySignature(*mainFunc, inputs))) {
     return failure();
   }
