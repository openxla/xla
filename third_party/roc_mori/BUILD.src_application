# Overlay BUILD for @roc_mori//src/application. Symlinked over the extracted
# tarball's src/application/BUILD.bazel by tf_http_archive (see workspace.bzl).
#
# Mirrors src/application/CMakeLists.txt: a single cc_library named
# mori_application. All sources are host C++ (CMake sets LANGUAGE CXX on
# them); they just call into the ROCm runtime APIs (HIP, HSA, rocm-smi,
# hsakmt) plus ibverbs/libpci. No device kernels live here.
#
# IMPORTANT: We use plain cc_library (not rocm_library) because
# rocm_library's default copts include ["-x", "rocm"] (see rocm_default_copts
# in @local_config_rocm//rocm:build_defs.bzl), which forces clang to treat
# every .cpp file as HIP source and excludes host-only overloads like
# hipMalloc(T**, size_t) and the host memset wrapper. That setup is meant
# for device kernel TUs, not for host code that merely calls HIP runtime
# APIs.
#
# Sources are globbed so new pure-CXX files added upstream get picked up
# automatically. The only exclusions are the two optional bootstraps that
# the upstream CMake gates on CMake knobs we have fixed OFF:
#   - bootstrap/mpi_bootstrap.cpp     (WITH_MPI=OFF)
#   - bootstrap/torch_bootstrap.cpp   (BUILD_TORCH_BOOTSTRAP=OFF)
load("@rules_cc//cc:cc_library.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "mori_application",
    srcs = glob(
        ["**/*.cpp"],
        exclude = [
            # Gated by WITH_MPI=ON in upstream CMake; our knobs fix WITH_MPI=OFF.
            "bootstrap/mpi_bootstrap.cpp",
            # Gated by BUILD_TORCH_BOOTSTRAP=ON in upstream CMake; OFF for us.
            "bootstrap/torch_bootstrap.cpp",
        ],
    ),
    copts = [
        # @local_config_rocm's rocm_headers_includes target propagates
        # -D__HIP_DISABLE_CPP_FUNCTIONS__=1 to every consumer, which hides
        # the templated hipMalloc(T**, size_t) overload. MORI's host code
        # (e.g. symmetric_memory.cpp) relies on that overload for implicit
        # T** -> void** conversion. Re-enable the C++ overloads for this TU.
        "-U__HIP_DISABLE_CPP_FUNCTIONS__",
        #
        # Note: WARP_ACCUM_UNROLL, HIP_ENABLE_WARP_SYNC_BUILTINS, __GFX9__,
        # MORI_DEVICE_NIC_BNXT / _IONIC are NOT added: verified unused in
        # src/application/** and include/mori/application/**. They belong on
        # the future shmem/ops device-code target.
    ],
    linkopts = [
        # CMake target_link_libraries(... dl ...)
        "-ldl",
    ],
    #linkstatic = False,
    alwayslink = True,
    deps = [
        "@roc_mori//:mori_application_headers",
        # symmetric_memory.cpp includes mori/shmem/internal.hpp.
        "@roc_mori//:mori_shmem_headers",
        # CMake hip::host: libamdhip64.so + HIP host headers.
        "@local_config_rocm//rocm:hip",
        # CMake find_library(ROCM_SMI_LIB rocm_smi64): librocm_smi64.so.
        "@local_config_rocm//rocm:rocm_smi",
        "@local_config_rocm//rocm:hsa_runtime",
        "@local_config_rocm//rocm:hsakmt",
        # CMake ibverbs: system libibverbs.so (rdma-core).
        "@roc_mori//:ibverbs",
        # CMake pci: system libpci.so (pciutils). pci.cpp uses pci_alloc / pci_init
        # / pci_scan_bus / pci_read_byte.
        "@roc_mori//:libpci",
        # System libdrm + libdrm_amdgpu. Required transitively by libhsakmt.a
        # (amdgpu_get_marketing_name, amdgpu_query_gpu_info, amdgpu_*, drmClose).
        "@roc_mori//:libdrm",
        # System libnuma. Required transitively by libhsakmt.a (numa_available,
        # numa_max_node, numa_bitmask_*, mbind, numa_node_size64).
        "@roc_mori//:libnuma",
        # mori_logging interface lib in CMake is spdlog::spdlog_header_only.
        "@spdlog//:spdlog",
    ],
)
